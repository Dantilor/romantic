# Password that unlocks the site.
SITE_PASSWORD=love-2026

# Secret used to sign the session cookie. Use a long random string in production.
AUTH_SECRET=please-change-me-to-a-long-random-string

# Secret path prefix. The site is reachable only via /<SECRET_PATH>/... on
# the first visit — anything else returns 404. After that, an http-only
# access cookie lets internal navigation use clean URLs.
# Pick something personal and non-guessable (no spaces, latin slug).
SECRET_PATH=our-little-month

# Optional: ISO date (YYYY-MM-DD) when day 1 becomes available.
# If unset, all days are unlocked (useful for development).
# START_DATE=2026-05-01
